[{"/home/shegos/Desktop/CurrentSprint/site/src/index.js":"1","/home/shegos/Desktop/CurrentSprint/site/src/App.js":"2","/home/shegos/Desktop/CurrentSprint/site/src/components/sidebar/Sidebar.js":"3","/home/shegos/Desktop/CurrentSprint/site/src/components/about/About.js":"4","/home/shegos/Desktop/CurrentSprint/site/src/components/education/Education.js":"5","/home/shegos/Desktop/CurrentSprint/site/src/components/skills/Skills.js":"6","/home/shegos/Desktop/CurrentSprint/site/src/components/hello/Greeter.js":"7"},{"size":197,"mtime":1612131747863,"results":"8","hashOfConfig":"9"},{"size":1164,"mtime":1612145006389,"results":"10","hashOfConfig":"9"},{"size":2177,"mtime":1612144464287,"results":"11","hashOfConfig":"9"},{"size":1060,"mtime":1611932518000,"results":"12","hashOfConfig":"9"},{"size":4471,"mtime":1611955920000,"results":"13","hashOfConfig":"9"},{"size":2070,"mtime":1611938326000,"results":"14","hashOfConfig":"9"},{"size":1738,"mtime":1612145096902,"results":"15","hashOfConfig":"9"},{"filePath":"16","messages":"17","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"18"},"1xkkvek",{"filePath":"19","messages":"20","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"21","usedDeprecatedRules":"18"},{"filePath":"22","messages":"23","errorCount":0,"warningCount":8,"fixableErrorCount":0,"fixableWarningCount":0,"source":"24","usedDeprecatedRules":"18"},{"filePath":"25","messages":"26","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"27","usedDeprecatedRules":"18"},{"filePath":"28","messages":"29","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"30","usedDeprecatedRules":"18"},{"filePath":"31","messages":"32","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"33","usedDeprecatedRules":"18"},{"filePath":"34","messages":"35","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"/home/shegos/Desktop/CurrentSprint/site/src/index.js",[],["36","37"],"/home/shegos/Desktop/CurrentSprint/site/src/App.js",["38"],"import React, { Fragment } from 'react';\nimport './App.css';\nimport { BrowserRouter as Router } from 'react-router-dom';\nimport Sidebar from './components/sidebar/Sidebar';\nimport About from './components/about/About';\nimport Education from './components/education/Education';\nimport Skills from './components/skills/Skills'\nimport Greeter from './components/hello/Greeter';\n\nfunction App() {\n  return (\n    <Router>\n      <div className=\"App\">\n        <div className=\"side\">\n          <nav className=\"navbar side navbar-expand-lg navbar-light p-0\" >\n            <button className=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" style={{ zIndex: '1' }}>\n              <span className=\"navbar-toggler-icon\"></span>\n            </button>\n            <div className=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n              <Sidebar />\n            </div>\n          </nav>\n        </div>\n        <div className=\"main\">\n          <div>\n\n            <Greeter />\n          </div>\n          <About />\n          <Skills />\n          <Education />\n\n        </div>\n      </div>\n    </Router>\n  )\n}\n\nexport default App;\n","/home/shegos/Desktop/CurrentSprint/site/src/components/sidebar/Sidebar.js",["39","40","41","42","43","44","45","46"],"import React, { Component } from 'react';\nimport './Sidebar.css';\nimport { HashLink as Link } from 'react-router-hash-link';\nimport logo from '../images/thato.jpg';\n\nfunction Sidebar() {\n    return (\n        <div className=\"sidebar\">\n            <img src={logo} />\n            <h1><Link smooth to=\"/#start\" className=\"h1_links\">Thato Mashego</Link></h1>\n            <p style={{ color: 'black', fontWeight: 'bold' }} className=\"gmail\"> cjmashego66@gmail.com </p>\n            <ul className=\"sidebar-nav\">\n                <li className=\"sidebar-nav-items\"><Link smooth to=\"/#about\" className=\"links\">About</Link></li>\n                <li className=\"sidebar-nav-items\"><Link smooth to=\"/#skills\" className=\"links\">Skills</Link></li>\n                <li className=\"sidebar-nav-items\"><Link smooth to=\"/#education\" className=\"links\" >Education</Link></li>\n            </ul>\n\n            <div className=\"flip-card-back\">\n                <ul className=\"sidebar-nav\">\n                    <li className=\"sidebar-nav-icons\"><a href=\"https://www.linkedin.com/in/thato-mashego-ab29b014b\" rel=\"opener noreferrer\" target=\"_blank\" class=\"fa fas fa-linkedin fa-lg\"></a></li>\n                    <li className=\"sidebar-nav-icons\"> <a href=\"https://github.com/ShegosThato\" rel=\"opener noreferrer\" target=\"_blank\" class=\"fa fas fa-github fa-lg\"></a></li>\n                    <li className=\"sidebar-nav-icons\"> <a href=\"https://twitter.com/shegosthato\" rel=\"opener noreferrer\" target=\"_blank\" className=\"fa fas fa-twitter fa-lg\"></a></li>\n                    <li className=\"sidebar-nav-icons\"> <a href=\"https://www.instagram.com/shegos_thato/\" rel=\"opener noreferrer\" target=\"_blank\" class=\"fa fas fa-instagram fa-lg\"></a></li>\n                    <li className=\"sidebar-nav-icons\"> <a href=\"mailto:cjmashego66@gmail.com\" rel=\"opener noreferrer\" target=\"_blank\" class=\"fa fas fa-envelope fa-lg\"></a></li>\n                    <li className=\"sidebar-nav-icons\"> <a href=\"https://www.facebook.com/profile.php?id=100004244502791\" rel=\"opener noreferrer\" target=\"_blank\" class=\"fa fas fa-facebook fa-lg\"></a></li>\n                </ul>\n            </div>\n\n        </div>\n    )\n}\n\nexport default Sidebar\n","/home/shegos/Desktop/CurrentSprint/site/src/components/about/About.js",["47"],"import React, { Component } from 'react'\nimport classes from './About.module.css';\nimport ScrollAnimation from 'react-animate-on-scroll';\nimport \"animate.css/animate.min.css\";\n\nfunction About() {\n    return (\n        <div className={classes.box} id=\"about\">\n            <ScrollAnimation offset=\"0\" animateIn=\"fadeInLeft\" duration='2.4' animateOnce=\"true\" initiallyVisible={true}>\n                <span className={classes.head}>ABOUT ME</span>\n                <h2 className={classes.heading}>Who Am I?</h2>\n                <div className={classes.About}>\n                    <p> I am a self-taught programmer from Brakpan, Ekurhuleni who loves fidgeting with web and mobile technologies. Grew up on Windows but ever since I discovered Linux, I never turned back.</p>\n                    <p className={classes.br}>I'm fascinated by how things work internally, I read a lot and often curious about new discoveries, ideas or just a new way of doing something. </p>\n                </div>\n            </ScrollAnimation>\n        </div>\n    )\n}\n\nexport default About;","/home/shegos/Desktop/CurrentSprint/site/src/components/education/Education.js",["48","49"],"import React, { Component } from 'react';\nimport classes from './education.module.css';\nimport ScrollAnimation from 'react-animate-on-scroll';\nimport \"animate.css/animate.min.css\";\nimport { MdSchool } from 'react-icons/md';\nimport { MdWork } from 'react-icons/md';\nimport { FaSchool } from 'react-icons/fa';\n\nfunction Education() {\n    return (\n        <div className={classes.box} id=\"education\">\n            <ScrollAnimation offset=\"0\" animateIn=\"fadeInLeft\" duration='2' animateOnce=\"true\" initiallyVisible={true}>\n                <span className={classes.head}>EDUCATION</span>\n                <section className={classes.container}>\n                    <div className={classes.container_content}>\n                        <div className={classes.row}>\n                            <div className={classes.row_md_12}>\n                                <div className={classes.timeline_centered}>\n                                    <ScrollAnimation offset=\"0\" animateIn=\"fadeInLeft\" duration='2.4' animateOnce=\"true\" initiallyVisible={true}>\n                                        <article className={classes.timeline_entry}>\n                                            <div className={`${classes.timeline_icon} ${classes.timeline_icon_2}`} >\n                                                <FaSchool />\n                                            </div>\n                                            <div className={classes.label}>\n                                                <h2 >HTS Springs <span>2009-2014</span></h2>\n                                                <p>My high school was a time of valuable life lessons and joy. Obtained my National Senior Certificate and was ready to conquer the world </p>\n                                            </div>\n                                        </article>\n                                    </ScrollAnimation>\n                                    <ScrollAnimation offset=\"0\" animateIn=\"fadeInLeft\" duration='2.4' animateOnce=\"true\" initiallyVisible={true}>\n                                        <article>\n                                            <div className={`${classes.timeline_icon} ${classes.timeline_icon_4}`} >\n                                                <MdWork />\n                                            </div>\n                                            <div className={classes.label}>\n                                                <h2 >First Job <span>2016-2017</span></h2>\n                                                <p>I was a Sales Consultant at a financial startup called Circle Finance from Edenvale.</p>\n                                            </div>\n                                            <br />\n                                            <div className={classes.label}>\n                                                <h2 >Work  <span>2017-2017</span></h2>\n                                                <p>Clerk at Keith Ho BetXChange, I was loved by customers because of my fast typing skills.</p>\n                                            </div>\n                                            <br />\n                                            <div className={classes.label}>\n                                                <h2 >Volunteering  <span>2019-2019</span></h2>\n                                                <p>Crystal Printing Designs is a printing company that I helped design and develop a website for.</p>\n                                            </div>\n                                            <br />\n                                            <div className={classes.label}>\n                                                <h2 >Volunteering  <span>2019-2020</span></h2>\n                                                <p>I helped a gym startup called NTM Fitness Club migrate digitally. I was a full stack developer that designed, developed and deployed the website.</p>\n                                            </div>\n                                            <div className={classes.timeline_entry_inner}><div className={classes.timeline_icon_3 || classes.color_none}></div></div>\n                                        </article>\n                                    </ScrollAnimation>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n            </ScrollAnimation>\n        </div>\n    )\n}\n\nexport default Education\n","/home/shegos/Desktop/CurrentSprint/site/src/components/skills/Skills.js",["50"],"import React, { Component } from 'react'\nimport classes from './skills.module.css';\nimport ScrollAnimation from 'react-animate-on-scroll';\nimport \"animate.css/animate.min.css\";\n\nfunction Skills() {\n    return (\n        <div className={classes.box} id=\"skills\">\n            <ScrollAnimation offset=\"0\" animateIn=\"fadeInLeft\" duration='2.4' animateOnce=\"true\" initiallyVisible={true}>\n                <span className={classes.head}>WHAT I DO?</span>\n                <h2 className={classes.heading}>HERE ARE SOME OF MY EXPERTISE</h2>\n                <div className={classes.skills}>\n                    <ScrollAnimation offset=\"0\" animateIn=\"fadeInLeft\" duration='2.4' animateOnce=\"true\" initiallyVisible={true}>\n                        <div className={classes.web}>\n                            <h3>Universal skills</h3>\n                            <p>I can use Windows, MacOS and Debian based Linux.<br /> GIMP, Inkscape, MS Office, Git and Github. </p>\n                        </div>\n                    </ScrollAnimation>\n                    <ScrollAnimation offset=\"0\" animateIn=\"fadeInLeft\" duration='2.4' animateOnce=\"true\" initiallyVisible={true}>\n                        <div className={classes.app}>\n                            <h3>Web Develpoment</h3>\n                            <p>I can build websites using HTML, CSS, Javascript, React, Django and the Django REST framework.<br /> I have also good grasp on Node, SQL(MySQL/PostgreSQL) and NoSQL(MongoDB)</p>\n                        </div>\n                    </ScrollAnimation>\n                    <ScrollAnimation offset=\"0\" animateIn=\"fadeInLeft\" duration='2.4' animateOnce=\"true\" initiallyVisible={true}>\n                        <div className={classes.other}>\n                            <h3>APP Development</h3>\n                            <p>I have beginner knowledge in React Native and Python Kivy framework and Android Studio.</p>\n                        </div>\n                    </ScrollAnimation>\n                </div>\n            </ScrollAnimation>\n        </div>\n    )\n}\n\nexport default Skills;","/home/shegos/Desktop/CurrentSprint/site/src/components/hello/Greeter.js",["51"],{"ruleId":"52","replacedBy":"53"},{"ruleId":"54","replacedBy":"55"},{"ruleId":"56","severity":1,"message":"57","line":1,"column":17,"nodeType":"58","messageId":"59","endLine":1,"endColumn":25},{"ruleId":"56","severity":1,"message":"60","line":1,"column":17,"nodeType":"58","messageId":"59","endLine":1,"endColumn":26},{"ruleId":"61","severity":1,"message":"62","line":9,"column":13,"nodeType":"63","endLine":9,"endColumn":31},{"ruleId":"64","severity":1,"message":"65","line":20,"column":55,"nodeType":"63","endLine":20,"endColumn":190},{"ruleId":"64","severity":1,"message":"65","line":21,"column":56,"nodeType":"63","endLine":21,"endColumn":168},{"ruleId":"64","severity":1,"message":"65","line":22,"column":56,"nodeType":"63","endLine":22,"endColumn":174},{"ruleId":"64","severity":1,"message":"65","line":23,"column":56,"nodeType":"63","endLine":23,"endColumn":180},{"ruleId":"64","severity":1,"message":"65","line":24,"column":56,"nodeType":"63","endLine":24,"endColumn":168},{"ruleId":"64","severity":1,"message":"65","line":25,"column":56,"nodeType":"63","endLine":25,"endColumn":195},{"ruleId":"56","severity":1,"message":"60","line":1,"column":17,"nodeType":"58","messageId":"59","endLine":1,"endColumn":26},{"ruleId":"56","severity":1,"message":"60","line":1,"column":17,"nodeType":"58","messageId":"59","endLine":1,"endColumn":26},{"ruleId":"56","severity":1,"message":"66","line":5,"column":10,"nodeType":"58","messageId":"59","endLine":5,"endColumn":18},{"ruleId":"56","severity":1,"message":"60","line":1,"column":17,"nodeType":"58","messageId":"59","endLine":1,"endColumn":26},{"ruleId":"67","severity":1,"message":"68","line":12,"column":17,"nodeType":"63","endLine":12,"endColumn":103},"no-native-reassign",["69"],"no-negated-in-lhs",["70"],"no-unused-vars","'Fragment' is defined but never used.","Identifier","unusedVar","'Component' is defined but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","jsx-a11y/anchor-has-content","Anchors must have content and the content must be accessible by a screen reader.","'MdSchool' is defined but never used.","jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","no-global-assign","no-unsafe-negation"]